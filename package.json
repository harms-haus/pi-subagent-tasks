{
  "name": "@harms-haus/pi-task-pools",
  "version": "0.1.0",
  "description": "pi-coding-agent extension: autonomous multi-task pool orchestrator with worktree isolation, concurrency limits, and a live TUI board",
  "type": "module",
  "main": "src/index.ts",
  "keywords": [
    "pi-package",
    "task-pools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src/**/*.ts",
    "!src/__tests__/**",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills/task-pools"
    ]
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typebox": "*",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pre-commit-check": "npm run format:check && npm run lint && npm run typecheck",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run pre-commit-check"
  }
}
